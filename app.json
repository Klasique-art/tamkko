{
  "expo": {
    "name": "tamkko",
    "slug": "tamkko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tamkko",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.tamkko.app",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.tamkko.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "notification": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#0A7EA4",
      "iosDisplayInForeground": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TAMKKO to access your photos so you can upload your ID front image.",
          "cameraPermission": "Allow TAMKKO to use the camera to capture your ID and selfie."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow TAMKKO to use your camera so you can record videos.",
          "microphonePermission": "Allow TAMKKO to use your microphone while recording videos."
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#0A7EA4"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "42478e86-3d60-4e76-8d58-76624559f24d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
